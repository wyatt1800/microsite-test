---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const guides = (await getCollection('guides')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<BaseLayout
  title="W-9 Guides — W9 Helper"
  description="Guides on IRS Form W-9: how to fill it out, who needs one, LLC tax classification, and what to expect after submitting."
>
  <Nav currentPath="/guides" />

  <main>
    <section style="padding: 60px 24px 72px; background-color: var(--color-off-white);">
      <div class="mx-auto max-w-3xl">

        <div style="margin-bottom: 48px;">
          <h1 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 34px; color: var(--color-text-primary); margin: 0 0 12px;">
            W-9 Guides
          </h1>
          <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 16px; color: var(--color-text-secondary); line-height: 1.7; margin: 0; max-width: 520px;">
            Everything you need to know about IRS Form W-9, without the tax jargon.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          {guides.map(guide => (
            <a
              href={`/guides/${guide.id}`}
              style={{
                display: 'block',
                backgroundColor: '#fff',
                border: '1px solid var(--color-border-brand)',
                borderRadius: 12,
                padding: '20px 24px',
                textDecoration: 'none',
                transition: 'border-color 0.15s, box-shadow 0.15s',
                boxShadow: '0 1px 3px rgba(15,23,42,0.05)',
              }}
              class="hover:border-blue-300 hover:shadow-md"
            >
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 16 }}>
                <div>
                  <h2 style={{ fontFamily: "'DM Sans', system-ui, sans-serif", fontSize: 17, fontWeight: 600, color: 'var(--color-text-primary)', margin: '0 0 6px', lineHeight: 1.4 }}>
                    {guide.data.title}
                  </h2>
                  <p style={{ fontFamily: "'DM Sans', system-ui, sans-serif", fontSize: 14, color: 'var(--color-text-secondary)', margin: 0, lineHeight: 1.6 }}>
                    {guide.data.description}
                  </p>
                </div>
                <span style={{ flexShrink: 0, color: 'var(--color-blue)', marginTop: 4 }}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>

        <!-- CTA -->
        <div
          style="margin-top: 56px; background: linear-gradient(135deg, var(--color-blue-light) 0%, var(--color-teal-light) 100%); border-radius: 14px; padding: 32px 28px; text-align: center; border: 1px solid var(--color-border-brand);"
        >
          <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; color: var(--color-text-primary); margin: 0 0 10px;">
            Ready to fill out your W-9?
          </h2>
          <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; color: var(--color-text-secondary); margin: 0 0 20px; line-height: 1.6;">
            It takes about three minutes. Clear guidance at every field.
          </p>
          <a
            href="/form"
            style="display: inline-flex; align-items: center; gap: 6px; background-color: var(--color-blue); color: #fff; font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; font-weight: 600; padding: 12px 24px; border-radius: 10px; text-decoration: none;"
            class="hover:opacity-90 transition-opacity"
          >
            Start your W-9 →
          </a>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
