---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found — W9 Helper" description="The page you're looking for doesn't exist.">
  <Nav />

  <main>
    <section style="padding: 100px 24px 120px; background-color: var(--color-off-white); min-height: calc(100vh - 128px); display: flex; align-items: center; justify-content: center;">
      <div style="text-align: center; max-width: 480px;">
        <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 13px; font-weight: 600; color: var(--color-blue); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 16px;">404</p>
        <h1 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 36px; color: var(--color-text-primary); margin: 0 0 16px; line-height: 1.2;">
          Page not found
        </h1>
        <p style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 15px; color: var(--color-text-secondary); line-height: 1.65; margin: 0 0 36px;">
          The page you're looking for doesn't exist or may have moved.
        </p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a
            href="/"
            style="display: inline-flex; align-items: center; gap: 7px; background-color: var(--color-blue); color: #fff; font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; font-weight: 600; padding: 12px 22px; border-radius: 8px; text-decoration: none;"
          >
            Go to homepage
          </a>
          <a
            href="/form"
            style="display: inline-flex; align-items: center; gap: 7px; background-color: #fff; color: var(--color-blue); border: 1px solid var(--color-border-brand); font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; font-weight: 600; padding: 12px 22px; border-radius: 8px; text-decoration: none;"
          >
            Fill out a W-9
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
