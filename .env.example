# Copy this file to .env for local development.
# Never commit .env or any file containing real secrets.
#
# Amplify: set these in App settings → Environment variables (per branch as needed).
# _CUSTOM_IMAGE=amplify:al2023   ← set this in Amplify build env so it uses Node 22.

# ── Analytics (public — safe to expose to the browser) ──────────────────────
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX

# ── SendGrid (server-side only — never prefix with PUBLIC_) ──────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
